# Copy this to .env for local development (optional)
# In production, set these in Render dashboard

# Required
HOST_PASSWORD=your-secret-password-here

# Optional — AI Scoring (requires ENABLE_AI_SCORING + at least one API key)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# ENABLE_AI_SCORING=true

# Optional — Override defaults
# AI_MODEL=claude-opus-4-7  # or gpt-5.5, gpt-5.4, claude-sonnet-4-20250514, gpt-4o-mini
# LOG_LEVEL=INFO
# SECRET_KEY=random-string-here
# GITHUB_TOKEN=ghp_...
# QR_BASE_URL=https://your-domain.com
# DEFAULT_THEME=classic   # Options: classic, dark, forest, stadium
